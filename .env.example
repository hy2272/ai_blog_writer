# Copy to .env (gitignored). The Gemini polish pass reads these.
GEMINI_API_KEY=your-google-ai-studio-key
# optional — current model id; override if the default 404s
GEMINI_MODEL=gemini-2.5-flash

# Apify — S0 news discovery (tools/news_discover.py) + 小红书 paradigm research.
# Token: console.apify.com/settings/integrations
APIFY_API_KEY=apify_api_your-token
APIFY_USER_ID=your-apify-user-id
